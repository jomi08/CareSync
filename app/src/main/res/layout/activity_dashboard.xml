<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F8FF">

    <!-- TOP APP BAR -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2E8BFF"
        android:paddingTop="24dp"
        android:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#2E8BFF"
            app:title="CareSync"
            app:titleTextColor="@android:color/white"/>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- GREETING CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="18dp"
            app:cardCornerRadius="20dp"
            android:layout_gravity="center_vertical"
            app:cardBackgroundColor="#2E8BFF"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="22dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hello, Doctor 👋"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvPatientCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 patients registered"
                    android:textColor="#DCEBFF"
                    android:textSize="14sp"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="All Patients"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:layout_marginHorizontal="18dp"
            android:layout_marginBottom="10dp"/>

        <!-- EMPTY STATE -->
        <TextView
            android:id="@+id/tvEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No patients yet.\nTap + to add one!"
            android:textAlignment="center"
            android:textSize="16sp"
            android:textColor="#7A7A7A"
            android:layout_gravity="center"
            android:layout_marginTop="80dp"
            android:visibility="gone"/>

        <!-- FILTER CHIPS -->
        <HorizontalScrollView
            android:id="@+id/scrollChips"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="4dp"
            android:paddingBottom="8dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAll"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All"
                    android:textStyle="bold"
                    android:checked="true"
                    app:chipBackgroundColor="#DCEBFF"
                    android:textColor="#005BFF"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipChildren"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Children (0–12)"
                    app:chipBackgroundColor="#EEF4FF"
                    android:textColor="#005BFF"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAdults"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Adults (13–59)"
                    app:chipBackgroundColor="#EEF4FF"
                    android:textColor="#005BFF"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipSenior"
                    style="@style/Widget.MaterialComponents.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Senior (60+)"
                    app:chipBackgroundColor="#EEF4FF"
                    android:textColor="#005BFF"/>

            </com.google.android.material.chip.ChipGroup>

        </HorizontalScrollView>

        <!-- PATIENT LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerPatients"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="100dp"/>

    </LinearLayout>

    <!-- SHARE FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabShare"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="90dp"
        android:src="@android:drawable/ic_menu_share"
        android:contentDescription="Share patient list"
        app:backgroundTint="#00B894"
        app:fabSize="mini"
        app:tint="@android:color/white"/>

    <!-- ADD FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:src="@android:drawable/ic_input_add"
        android:contentDescription="Add patient"
        app:backgroundTint="#2E8BFF"
        app:tint="@android:color/white"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>